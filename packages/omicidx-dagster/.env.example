# PostgreSQL Configuration (required for run execution)
# These should match your Dagster deployment's postgres settings
DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=your-postgres-password
DAGSTER_POSTGRES_DB=dagster
DAGSTER_POSTGRES_HOSTNAME=pg_main
DAGSTER_POSTGRES_PORT=5432

# S3/R2 Storage Configuration
S3_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto
S3_URL_STYLE=path

# OmicIDX publish root
# Production: s3://omicidx
# Development: /tmp/omicidx-dev or local path
PUBLISH_ROOT=s3://omicidx

# Dagster settings (optional)
DAGSTER_LOG_LEVEL=INFO
